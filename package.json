{
  "name": "pixels-scraper",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "clean-urls": "bun src/lib/clean-urls.ts",
    "db:generate": "bun x --bun drizzle-kit generate",
    "db:migrate": "bun x --bun drizzle-kit migrate",
    "db:reset": "bun run src/db/reset.ts",
    "db:studio": "bun x --bun drizzle-kit studio",
    "dev": "docker compose up -d && bun src/index.ts",
    "format": "oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "crawlee": "^3.16.0",
    "drizzle-orm": "^0.45.1",
    "pino": "^10.3.1",
    "playwright": "^1.58.2",
    "postgres": "^3.4.8",
    "tldts": "^7.0.24"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "drizzle-kit": "^0.31.9",
    "lefthook": "^2.1.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3"
  }
}
